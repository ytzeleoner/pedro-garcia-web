---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Portfolio y blog de Pedro García — Agile Coach y estratega de IA.' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Pedro García</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-white text-gray-900 font-sans antialiased">
    <header class="border-b border-gray-100 py-4 px-6 flex items-center justify-between max-w-4xl mx-auto">
      <a href="/" class="font-semibold text-gray-900 hover:text-blue-600 transition-colors">
        Pedro García
      </a>
      <nav class="flex gap-6 text-sm text-gray-600">
        <a href="/proyectos" class="hover:text-gray-900 transition-colors">Proyectos</a>
        <a href="/conceptos" class="hover:text-gray-900 transition-colors">Conceptos</a>
      </nav>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-gray-100 py-8 px-6 text-center text-sm text-gray-400 mt-16">
      <p>Pedro García · <a href="https://github.com/pedrogarcia" class="hover:text-gray-600">GitHub</a> · <a href="https://linkedin.com/in/pedrogarcia" class="hover:text-gray-600">LinkedIn</a></p>
    </footer>
  </body>
</html>
