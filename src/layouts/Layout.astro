---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Portfolio y blog de Pedro García — Agile Coach y estratega de IA.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Pedro García</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  </head>
  <body>
    <header class="sticky top-0 z-50 border-b border-white/5" style="background: rgba(10,10,20,0.8); backdrop-filter: blur(16px);">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={`${base}/`} class="font-semibold text-white hover:text-violet-300 transition-colors tracking-tight">
          Pedro García
        </a>
        <nav class="flex gap-7 text-sm text-slate-400">
          <a href={`${base}/experiencia`} class="hover:text-white transition-colors">Experiencia</a>
          <a href={`${base}/proyectos`} class="hover:text-white transition-colors">Proyectos</a>
          <a href={`${base}/conceptos`} class="hover:text-white transition-colors">Conceptos</a>
          <a href={`${base}/blog`} class="hover:text-white transition-colors">Blog</a>
        </nav>
      </div>
    </header>

    <main class="max-w-4xl mx-auto px-6 py-16">
      <slot />
    </main>

    <footer class="border-t border-white/5 py-10 px-6 mt-20">
      <div class="max-w-4xl mx-auto flex items-center justify-between text-sm text-slate-500">
        <span class="mono">pedro-garcia.dev</span>
        <div class="flex gap-6">
          <a href="https://github.com/pedrogarcia" class="hover:text-slate-300 transition-colors">GitHub</a>
          <a href="https://linkedin.com/in/pedrogarcia" class="hover:text-slate-300 transition-colors">LinkedIn</a>
        </div>
      </div>
    </footer>
  </body>
</html>
