---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const publicaciones = await getCollection('publicaciones').catch(() => []);
  return publicaciones
    .filter(p => p.data.tags?.includes('publicable') && p.data.estado === 'publicado')
    .map(p => ({ params: { slug: p.id }, props: { articulo: p } }));
}

const { articulo } = Astro.props;
const { Content } = await render(articulo);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const titulo = articulo.data.titulo ?? articulo.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
const fecha = articulo.data.created?.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={titulo}>
  <!-- Breadcrumb -->
  <nav style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);margin-bottom:var(--s-8);display:flex;align-items:center;gap:var(--s-2);">
    <a href={`${base}/`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Inicio</a>
    <span>·</span>
    <a href={`${base}/blog`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Blog</a>
  </nav>

  <!-- Header -->
  <header style="margin-bottom:var(--s-9);max-width:64ch;">
    {articulo.data.extracto && (
      <p class="mono" style="margin-bottom:var(--s-4);">{articulo.data.extracto.split(' ').slice(0, 6).join(' ')}…</p>
    )}
    <h1 style="font-size:clamp(28px,4vw,40px);font-weight:var(--fw-bold);color:var(--text);letter-spacing:var(--ls-tight-3);line-height:1.15;margin-bottom:var(--s-4);">
      {titulo}
    </h1>
    {articulo.data.extracto && (
      <p style="font-size:var(--fs-lede);color:var(--text-2);line-height:1.55;margin-bottom:var(--s-5);">{articulo.data.extracto}</p>
    )}
    {fecha && <p style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);">{fecha}</p>}
  </header>

  <hr class="divider" />

  <!-- Contenido -->
  <article class="prose" style="max-width:64ch;">
    <Content />
  </article>

  <hr class="divider" />

  <!-- Footer artículo -->
  <footer style="display:flex;align-items:center;justify-content:space-between;">
    <a href={`${base}/blog`} style="font-size:13px;color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">← Volver al blog</a>
    <a href="https://linkedin.com/in/pedrogarcia" style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--accent);">Conectar en LinkedIn →</a>
  </footer>
</Layout>
