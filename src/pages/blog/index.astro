---
import Layout from '../../layouts/Layout.astro';

const articulos = [
  {
    titulo: 'Los tres patrones de uso de IA en ingeniería de construcción',
    descripcion: 'Cómo los equipos de ingeniería civil están adoptando IA: tres perfiles distintos con necesidades y riesgos diferentes.',
    tema: 'IA aplicada',
  },
  {
    titulo: 'Por qué Copilot no es suficiente',
    descripcion: 'La tensión entre contratos corporativos con Microsoft y las herramientas que los equipos técnicos realmente necesitan.',
    tema: 'IA · Estrategia',
  },
  {
    titulo: 'Cómo la IA está cambiando el trabajo en obra: el caso de North London',
    descripcion: 'Un ingeniero de estructuras usa IA para convertir planos en tablas de Excel paginadas. Parece pequeño. No lo es.',
    tema: 'Caso de uso',
  },
  {
    titulo: 'Agile Coach en la era de la IA: cómo cambia el rol',
    descripcion: 'La IA no sustituye la facilitación — pero obliga a replantear qué aporta el coach cuando el equipo genera código y documentación en minutos.',
    tema: 'Agile · IA',
  },
  {
    titulo: 'Cómo integré Claude Code con Obsidian para gestionar mi diario profesional',
    descripcion: 'Un sistema de gestión del conocimiento personal construido sobre Obsidian y Claude Code. Cómo funciona y por qué lo construí.',
    tema: 'Herramientas',
  },
];
---

<Layout title="Blog">
  <p class="mono" style="margin-bottom:var(--s-3);">blog</p>
  <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);margin-bottom:var(--s-3);letter-spacing:var(--ls-tight-3);">Blog</h1>
  <p style="color:var(--text-2);margin-bottom:var(--s-9);max-width:52ch;">Reflexiones sobre Agile, IA aplicada y trabajo en organizaciones de ingeniería.</p>

  <section>
    <div class="seclabel"><span class="num">—</span> En preparación <span class="line"></span></div>
    <div style="display:flex;flex-direction:column;gap:var(--s-3);">
      {articulos.map(a => (
        <div class="glass" style="padding:var(--s-5);display:flex;align-items:flex-start;justify-content:space-between;gap:var(--s-6);">
          <div style="flex:1;min-width:0;">
            <p class="mono" style="margin-bottom:var(--s-2);">{a.tema}</p>
            <h3 style="font-weight:var(--fw-semi);color:var(--text);margin-bottom:var(--s-2);line-height:1.35;">{a.titulo}</h3>
            <p style="font-size:13px;color:var(--text-2);line-height:1.6;">{a.descripcion}</p>
          </div>
          <span class="badge-soon" style="flex-shrink:0;align-self:flex-start;">draft</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
