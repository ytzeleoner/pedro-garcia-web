---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const conceptos = await getCollection('conceptos');
  return conceptos
    .filter(c => c.data.tags.includes('publicable'))
    .map(c => ({ params: { slug: c.id }, props: { concepto: c } }));
}

const { concepto } = Astro.props;
const { Content } = await render(concepto);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={concepto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-slate-500 mb-10 flex items-center gap-2">
    <a href={`${base}/`} class="hover:text-slate-300 transition-colors">Inicio</a>
    <span>·</span>
    <a href={`${base}/conceptos`} class="hover:text-slate-300 transition-colors">Conceptos</a>
  </nav>

  <!-- Header -->
  <header class="mb-12">
    <h1 class="text-3xl font-bold text-white tracking-tight mb-4">
      {concepto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
    </h1>
    <div class="flex gap-2 flex-wrap">
      {concepto.data.tags
        .filter(t => t !== 'publicable' && !t.startsWith('wiki/'))
        .map(tag => (
          <span class="glass text-xs text-slate-400 px-2 py-0.5 rounded">{tag}</span>
        ))
      }
    </div>
  </header>

  <!-- Contenido -->
  <article class="prose max-w-none">
    <Content />
  </article>
</Layout>
