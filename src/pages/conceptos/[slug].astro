---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const conceptos = await getCollection('conceptos');
  return conceptos
    .filter(c => c.data.tags.includes('publicable'))
    .map(c => ({ params: { slug: c.id }, props: { concepto: c } }));
}

const { concepto } = Astro.props;
const { Content } = await render(concepto);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={concepto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}>
  <!-- Breadcrumb -->
  <nav style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);margin-bottom:var(--s-8);display:flex;align-items:center;gap:var(--s-2);">
    <a href={`${base}/`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Inicio</a>
    <span>·</span>
    <a href={`${base}/conceptos`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Conceptos</a>
  </nav>

  <!-- Header -->
  <header style="margin-bottom:var(--s-9);">
    <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);letter-spacing:var(--ls-tight-3);margin-bottom:var(--s-4);">
      {concepto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
    </h1>
    <div style="display:flex;gap:var(--s-2);flex-wrap:wrap;">
      {concepto.data.tags
        .filter((t: string) => t !== 'publicable' && !t.startsWith('wiki/'))
        .map((tag: string) => (
          <span style="background:var(--card);border:var(--bd);border-radius:var(--r-sm);padding:2px var(--s-2);font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);">{tag}</span>
        ))
      }
    </div>
  </header>

  <!-- Contenido -->
  <article class="prose" style="max-width:none;">
    <Content />
  </article>
</Layout>
