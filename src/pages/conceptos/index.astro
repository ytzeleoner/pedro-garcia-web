---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const conceptos = (await getCollection('conceptos'))
  .filter(c => c.data.tags.includes('publicable'))
  .sort((a, b) => (b.data.created?.getTime() ?? 0) - (a.data.created?.getTime() ?? 0));
---

<Layout title="Conceptos">
  <p class="mono" style="margin-bottom:var(--s-3);">conceptos</p>
  <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);margin-bottom:var(--s-3);letter-spacing:var(--ls-tight-3);">Conceptos</h1>
  <p style="color:var(--text-2);margin-bottom:var(--s-9);max-width:52ch;">Metodologías, patrones y marcos destilados de la experiencia.</p>

  <div style="display:flex;flex-direction:column;gap:var(--s-3);">
    {conceptos.map(c => (
      <a href={`${base}/conceptos/${c.id}`} class="glass" style="padding:var(--s-5);display:flex;align-items:flex-start;justify-content:space-between;gap:var(--s-4);">
        <div>
          <h2 style="font-weight:var(--fw-semi);color:var(--text);margin-bottom:var(--s-2);">
            {c.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
          </h2>
          <div style="display:flex;gap:var(--s-2);flex-wrap:wrap;">
            {c.data.tags.filter((t: string) => t !== 'publicable' && !t.startsWith('wiki/')).slice(0, 3).map((tag: string) => (
              <span class="mono">{tag}</span>
            ))}
          </div>
        </div>
        <span style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--accent);flex-shrink:0;align-self:center;">→</span>
      </a>
    ))}
  </div>
</Layout>
