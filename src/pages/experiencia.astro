---
import Layout from '../layouts/Layout.astro';

const etapas = [
  {
    cliente: 'Acciona',
    iniciales: 'AC',
    rol: 'Agile Coach · Consultor IA',
    periodo: '2019 – actualidad',
    descripcion: 'Transformación Agile en Mobility, gestión de roadmaps en TIC Construcción y estrategia de adopción de IA para el departamento de ingeniería de una organización de 40.000+ personas.',
    activo: true,
  },
  {
    cliente: 'Kairos / MasMovil',
    iniciales: 'KA',
    rol: 'Scrum Master',
    periodo: '2018 – 2019',
    descripcion: 'Primer proyecto en Kairos como consultor, con MasMovil en plena fase de crecimiento acelerado hacia los cuatro grandes del mercado español.',
    activo: false,
  },
  {
    cliente: 'Accenture',
    iniciales: 'AC',
    rol: 'Líder técnico',
    periodo: '~2006 – 2017 · 11 años',
    descripcion: 'Once años liderando proyectos de desarrollo de software para múltiples clientes en distintos sectores. Base técnica del perfil actual.',
    activo: false,
  },
];

const logros = [
  {
    titulo: 'Transformación Agile a escala',
    contexto: 'Acciona Mobility · 2019–2021',
    descripcion: 'Construí 6 equipos Scrum desde cero con Nexus para dependencias cross-equipo. El framework se replicó en Innovación Digital y sigue en uso.',
    metrica: '6 equipos operativos desde cero',
  },
  {
    titulo: 'Despliegues ×10 más rápidos',
    contexto: 'Acciona Mobility · 2020',
    descripcion: 'Reduje el tiempo de despliegue mediante rotura del monolito y compilación incremental de módulos.',
    metrica: '30 min → 3 min',
  },
  {
    titulo: 'Visibilidad de la demanda real',
    contexto: 'Acciona Mobility · 2020',
    descripcion: 'Demostré con datos que la cola de trabajo equivalía a más de un año, forzando una priorización real entre stakeholders.',
    metrica: '+1 año de cola visualizado',
  },
  {
    titulo: 'Vista de dependencias en roadmap',
    contexto: 'Acciona TIC Construcción · 2024',
    descripcion: 'Implementé una vista de dependencias activas en Jira Advanced Roadmaps que detectó bloqueos cruzados no visibles hasta entonces.',
    metrica: 'Bloqueos ocultos detectados',
  },
];
---

<Layout title="Experiencia">
  <p class="mono mb-3">experiencia</p>
  <h1 class="text-3xl font-bold text-white mb-3 tracking-tight">Trayectoria</h1>
  <p class="text-slate-400 mb-14 max-w-lg">Roles, logros medibles y proyectos que han dejado huella.</p>

  <!-- Timeline ─────────────────────────────────────────── -->
  <section class="mb-20">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-widest mb-6">Historial</h2>
    <div class="space-y-4">
      {etapas.map(e => (
        <div class="glass p-5 flex gap-5">
          <div class="w-11 h-11 rounded-xl flex items-center justify-center text-xs font-bold shrink-0"
               style="background: rgba(139,92,246,0.15); color: #a78bfa; border: 1px solid rgba(139,92,246,0.25);">
            {e.iniciales}
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2 mb-1">
              <h3 class="font-semibold text-white">{e.cliente}</h3>
              {e.activo && <span class="badge-active shrink-0">actual</span>}
            </div>
            <p class="text-sm text-slate-400 mb-2">{e.rol} <span class="text-slate-600 mx-1">·</span> <span class="mono text-xs">{e.periodo}</span></p>
            <p class="text-sm text-slate-300 leading-relaxed">{e.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Logros ───────────────────────────────────────────── -->
  <section>
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-widest mb-6">Logros destacados</h2>
    <div class="grid gap-4 sm:grid-cols-2">
      {logros.map(l => (
        <div class="glass p-5">
          <p class="mono mb-2">{l.contexto}</p>
          <h3 class="font-semibold text-white mb-2">{l.titulo}</h3>
          <p class="text-sm text-slate-400 leading-relaxed mb-4">{l.descripcion}</p>
          <span class="metric">{l.metrica}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
