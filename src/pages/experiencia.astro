---
import Layout from '../layouts/Layout.astro';

const etapas = [
  {
    cliente: 'Acciona',
    iniciales: 'AC',
    rol: 'Agile Coach · Consultor IA',
    periodo: '2019 – actualidad',
    descripcion: 'Transformación Agile en Mobility, gestión de roadmaps en TIC Construcción y estrategia de adopción de IA para el departamento de ingeniería de una organización de 40.000+ personas.',
    activo: true,
  },
  {
    cliente: 'Kairos / MasMovil',
    iniciales: 'KA',
    rol: 'Scrum Master',
    periodo: '2018 – 2019',
    descripcion: 'Primer proyecto en Kairos como consultor, con MasMovil en plena fase de crecimiento acelerado hacia los cuatro grandes del mercado español.',
    activo: false,
  },
  {
    cliente: 'Accenture',
    iniciales: 'AC',
    rol: 'Líder técnico',
    periodo: '~2006 – 2017 · 11 años',
    descripcion: 'Once años liderando proyectos de desarrollo de software para múltiples clientes en distintos sectores. Base técnica del perfil actual.',
    activo: false,
  },
];

const logros = [
  {
    titulo: 'Transformación Agile a escala',
    contexto: 'Acciona Mobility · 2019–2021',
    descripcion: 'Construí 6 equipos Scrum desde cero con Nexus para dependencias cross-equipo. El framework se replicó en Innovación Digital y sigue en uso.',
    metrica: '6 equipos operativos desde cero',
  },
  {
    titulo: 'Despliegues ×10 más rápidos',
    contexto: 'Acciona Mobility · 2020',
    descripcion: 'Reduje el tiempo de despliegue mediante rotura del monolito y compilación incremental de módulos.',
    metrica: '30 min → 3 min',
  },
  {
    titulo: 'Visibilidad de la demanda real',
    contexto: 'Acciona Mobility · 2020',
    descripcion: 'Demostré con datos que la cola de trabajo equivalía a más de un año, forzando una priorización real entre stakeholders.',
    metrica: '+1 año de cola visualizado',
  },
  {
    titulo: 'Vista de dependencias en roadmap',
    contexto: 'Acciona TIC Construcción · 2024',
    descripcion: 'Implementé una vista de dependencias activas en Jira Advanced Roadmaps que detectó bloqueos cruzados no visibles hasta entonces.',
    metrica: 'Bloqueos ocultos detectados',
  },
];
---

<Layout title="Experiencia">
  <p class="mono" style="margin-bottom:var(--s-3);">experiencia</p>
  <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);margin-bottom:var(--s-3);letter-spacing:var(--ls-tight-3);">Trayectoria</h1>
  <p style="color:var(--text-2);margin-bottom:var(--s-9);max-width:42ch;">Roles, logros medibles y proyectos que han dejado huella.</p>

  <!-- Timeline -->
  <section style="margin-bottom:var(--s-10);">
    <div class="seclabel"><span class="num">01</span> Historial <span class="line"></span></div>
    <div style="display:flex;flex-direction:column;gap:var(--s-3);">
      {etapas.map(e => (
        <div class="glass" style="padding:var(--s-5);display:flex;gap:var(--s-5);">
          <div style="width:44px;height:44px;border-radius:var(--r-xl);display:flex;align-items:center;justify-content:center;font-size:var(--fs-mono);font-weight:var(--fw-bold);flex-shrink:0;background:var(--accent-soft);color:var(--accent);border:1px solid rgba(197,255,74,.2);font-family:var(--font-mono);">
            {e.iniciales}
          </div>
          <div style="flex:1;min-width:0;">
            <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:var(--s-2);margin-bottom:var(--s-1);">
              <h3 style="font-weight:var(--fw-semi);color:var(--text);">{e.cliente}</h3>
              {e.activo && <span class="badge-active">actual</span>}
            </div>
            <p style="font-size:13px;color:var(--text-2);margin-bottom:var(--s-2);">{e.rol} <span style="color:var(--line-2);margin:0 4px;">·</span> <span style="font-family:var(--font-mono);font-size:var(--fs-mono);">{e.periodo}</span></p>
            <p style="font-size:13px;color:var(--text-2);line-height:1.6;">{e.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Logros -->
  <section>
    <div class="seclabel"><span class="num">02</span> Logros destacados <span class="line"></span></div>
    <div style="display:grid;gap:var(--s-4);grid-template-columns:repeat(auto-fill,minmax(260px,1fr));">
      {logros.map(l => (
        <div class="glass" style="padding:var(--s-5);">
          <p class="mono" style="margin-bottom:var(--s-2);">{l.contexto}</p>
          <h3 style="font-weight:var(--fw-semi);color:var(--text);margin-bottom:var(--s-2);">{l.titulo}</h3>
          <p style="font-size:13px;color:var(--text-2);line-height:1.6;margin-bottom:var(--s-4);">{l.descripcion}</p>
          <span class="badge-active">{l.metrica}</span>
        </div>
      ))}
    </div>
  </section>
</Layout>
