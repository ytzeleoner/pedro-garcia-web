<script>
  const wait = (ms: number) => new Promise<void>(r => setTimeout(r, ms));
  let cancelAll = false;

  const typeHTML = (el: HTMLElement, html: string, speed: number) => new Promise<void>(res => {
    let i = 0;
    const tick = () => {
      if (cancelAll) { el.innerHTML = html; return res(); }
      if (html[i] === '<') {
        const close = html.indexOf('>', i);
        if (close < 0) { el.innerHTML = html; return res(); }
        i = close + 1;
      } else { i++; }
      if (i >= html.length) { el.innerHTML = html; return res(); }
      el.innerHTML = html.slice(0, i) + '<span class="type-cursor"></span>';
      setTimeout(tick, speed + (Math.random() * speed * 0.4 - speed * 0.2));
    };
    tick();
  });

  const typeText = (el: HTMLElement, text: string, speed: number) => new Promise<void>(res => {
    let i = 0;
    const tick = () => {
      if (cancelAll) { el.textContent = text; return res(); }
      el.textContent = text.slice(0, ++i);
      if (i < text.length) setTimeout(tick, speed);
      else res();
    };
    tick();
  });

  // ── Hero setup ──
  const h1 = document.querySelector('.hero h1[data-typing]') as HTMLElement;
  const lede = document.querySelector('.hero .lede[data-typing]') as HTMLElement;
  const H1_HTML = h1 ? h1.innerHTML.trim() : '';
  const LEDE_HTML = lede ? lede.innerHTML.trim() : '';
  if (h1) { h1.style.minHeight = h1.offsetHeight + 'px'; h1.innerHTML = '<span class="type-cursor"></span>'; h1.classList.add('ready'); }
  if (lede) { lede.style.minHeight = lede.offsetHeight + 'px'; lede.innerHTML = ''; lede.classList.add('ready'); }

  // ── Profile card setup ──
  const profileRows = Array.from(document.querySelectorAll('.info-card dl > div')) as HTMLElement[];
  const profileCard = document.querySelector('.info-card') as HTMLElement;
  const KEEP_KEYS = new Set(['rol','foco','estado']);
  const profileData = profileRows.map(row => {
    const dt = row.querySelector('dt') as HTMLElement;
    const dd = row.querySelector('dd') as HTMLElement;
    return { row, dt, dd, key: dt.textContent ?? '', valueHTML: dd.innerHTML.trim() };
  });
  profileRows.forEach(r => { r.style.opacity = '0'; });
  profileData.forEach(p => { p.dt.textContent = ''; p.dd.innerHTML = ''; });

  const typeProfile = async () => {
    for (const p of profileData) {
      p.row.style.opacity = '1';
      for (let i = 0; i <= p.key.length; i++) { p.dt.textContent = p.key.slice(0, i); await wait(14); }
      await wait(60);
      let i = 0; const html = p.valueHTML;
      while (i < html.length) {
        if (html[i] === '<') { const c = html.indexOf('>', i); if (c < 0) break; i = c + 1; } else { i++; }
        p.dd.innerHTML = html.slice(0, i); await wait(10);
      }
      p.dd.innerHTML = html; await wait(60);
    }
  };

  const collapseProfile = async () => {
    await wait(500);
    profileData.forEach(p => { if (!KEEP_KEYS.has(p.key)) p.row.classList.add('collapsed'); });
    profileCard.classList.add('compact');
    const heroRight = document.querySelector('.hero-right') as HTMLElement;
    const photo = document.querySelector('.hero-photo') as HTMLElement;
    heroRight.classList.add('with-photo');
    await wait(280);
    photo.classList.add('shown');
  };

  const revealProfile = () => {
    profileData.forEach(p => {
      p.dt.textContent = p.key; p.dd.innerHTML = p.valueHTML; p.row.style.opacity = '1';
      if (!KEEP_KEYS.has(p.key)) p.row.classList.add('collapsed');
    });
    profileCard.classList.add('compact');
    (document.querySelector('.hero-right') as HTMLElement).classList.add('with-photo');
    (document.querySelector('.hero-photo') as HTMLElement).classList.add('shown');
  };

  // ── Overlay ──
  const overlay = document.getElementById('gen') as HTMLElement;
  const promptEl = document.getElementById('genPrompt') as HTMLElement;
  const outEl = document.getElementById('genOut') as HTMLElement;
  const cursor = document.getElementById('genCursor') as HTMLElement;
  const skipBtn = document.getElementById('genSkip') as HTMLElement;

  const PROMPT_TXT = 'generate experience.profile("pedro_garcía") --stream';
  const OUT_LINES = [
    '✓ rol: agile_coach × ai_strategy',
    '✓ scope: 40.000+ personas · acciona',
    '✓ construyendo: sistemas que escalan',
    '✓ base: madrid · cet · disponible',
    '✓ render: ok →'
  ];

  const dismissOverlay = () => {
    overlay.classList.add('done');
    setTimeout(() => overlay.remove(), 600);
    sessionStorage.setItem('pg-intro-played', '1');
  };

  const playOverlay = async () => {
    await wait(250);
    await typeText(promptEl, PROMPT_TXT, 22);
    if (cancelAll) return;
    await wait(380);
    let acc = '';
    for (const line of OUT_LINES) {
      if (cancelAll) return;
      for (let j = 0; j <= line.length; j++) {
        if (cancelAll) return;
        outEl.textContent = acc + line.slice(0, j);
        await wait(8);
      }
      acc += line + '\n';
      outEl.textContent = acc;
      await wait(140);
    }
    cursor.style.background = 'var(--text-3)';
    await wait(500);
    if (!cancelAll) dismissOverlay();
  };

  skipBtn.addEventListener('click', () => {
    cancelAll = true;
    dismissOverlay();
    if (h1) { h1.innerHTML = H1_HTML; h1.style.minHeight = ''; }
    if (lede) { lede.innerHTML = LEDE_HTML; lede.style.minHeight = ''; }
    revealProfile();
  });

  // ── Main flow ──
  (async () => {
    const firstVisit = !sessionStorage.getItem('pg-intro-played');
    if (firstVisit) {
      await playOverlay();
      if (cancelAll) return;
      cancelAll = false;
      await wait(280);
      await typeProfile();
      await collapseProfile();
      await wait(200);
      await typeHTML(h1, H1_HTML, 38);
      h1.style.minHeight = '';
      await wait(160);
      await typeHTML(lede, LEDE_HTML, 14);
      lede.style.minHeight = '';
    } else {
      overlay.remove();
      revealProfile();
      await wait(180);
      await typeHTML(h1, H1_HTML, 38);
      h1.style.minHeight = '';
      await wait(160);
      await typeHTML(lede, LEDE_HTML, 14);
      lede.style.minHeight = '';
    }
  })();

  // ── Scroll progress ──
  const bar = document.getElementById('scrollbar') as HTMLElement;
  const upd = () => {
    const h = document.documentElement;
    bar.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
  };
  window.addEventListener('scroll', upd, { passive: true });
  upd();

  // ── Shimmer (secciones, no hero — el hero se tipea) ──
  const shimEls = document.querySelectorAll('.sec .shim');
  const shimIo = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      if (el.dataset.shimmed === '1') return;
      el.dataset.shimmed = '1';
      const alts = (el.dataset.alts || '').split('|').filter(Boolean);
      el.classList.add('active');
      if (!alts.length) { setTimeout(() => el.classList.remove('active'), 900); return; }
      const original = el.textContent ?? '';
      const seq = alts.slice(1).concat([original]);
      let i = 0;
      const tick = () => {
        if (i >= seq.length) { el.textContent = original; setTimeout(() => el.classList.remove('active'), 500); return; }
        el.textContent = seq[i++]; setTimeout(tick, 220);
      };
      setTimeout(tick, 180);
    });
  }, { threshold: .7 });
  shimEls.forEach(el => shimIo.observe(el));

  // ── Count up ──
  const countEls = document.querySelectorAll('[data-countto]');
  const countIo = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      countIo.unobserve(el);
      const to = parseFloat(el.dataset.countto ?? '0');
      const html = el.innerHTML;
      const m = html.match(/(\d+)/);
      if (!m) return;
      const dur = 1100, t0 = performance.now();
      const tick = (t: number) => {
        const p = Math.min(1, (t - t0) / dur);
        const eased = 1 - Math.pow(1 - p, 3);
        el.innerHTML = html.replace(m[1], String(Math.round(to * eased)));
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    });
  }, { threshold: .5 });
  countEls.forEach(el => countIo.observe(el));

  // ── Cmd+K → blog/ask ──
  window.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
      e.preventDefault();
      window.location.href = `${document.querySelector('nav.top .brand')?.getAttribute('href') ?? ''}/blog`;
    }
  });
</script>

</body>
