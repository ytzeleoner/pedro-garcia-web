---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const proyectos = (await getCollection('proyectos'))
  .filter(p => p.data.tags.includes('publicable'))
  .sort((a, b) => (b.data.created?.getTime() ?? 0) - (a.data.created?.getTime() ?? 0))
  .slice(0, 4);

const titulos: Record<string, string> = {
  'rol-ia-acciona': 'Estrategia de IA en Ingeniería',
  'adaptador-iniciativas-jira': 'Automatización Jira + Google Sheets',
  'transformacion-agile-mobility': 'Transformación Agile a escala',
  'scrum-master-masmovil-kairos': 'Scrum Master en MasMovil',
  'lider-tecnico-accenture': 'Líder técnico — Accenture',
};

const descripciones: Record<string, string> = {
  'rol-ia-acciona': 'Programa de Key Players, clasificación de casos de uso y roadmap de herramientas IA para 40.000+ personas.',
  'adaptador-iniciativas-jira': 'Pipeline Python que carga iniciativas desde Google Sheets a Jira Advanced Roadmaps en segundos.',
  'transformacion-agile-mobility': '6 equipos Scrum desde cero con Nexus. De monolito a despliegues ×10 más rápidos.',
  'scrum-master-masmovil-kairos': 'Acompañamiento ágil en MasMovil durante su fase de crecimiento acelerado.',
  'lider-tecnico-accenture': '11 años liderando proyectos de desarrollo de software para múltiples clientes.',
};

const orgs: Record<string, string> = {
  'rol-ia-acciona': 'acciona / ai_strategy',
  'adaptador-iniciativas-jira': 'acciona / automation',
  'transformacion-agile-mobility': 'acciona / agile',
  'scrum-master-masmovil-kairos': 'kairos / masmovil',
  'lider-tecnico-accenture': 'accenture · 11 años',
};

const codes: Record<string, string> = {
  'rol-ia-acciona': 'P-001',
  'adaptador-iniciativas-jira': 'P-002',
  'transformacion-agile-mobility': 'P-003',
  'scrum-master-masmovil-kairos': 'P-004',
  'lider-tecnico-accenture': 'P-005',
};

const etapas = [
  { when: '→ 2019 – actualidad', now: true, empresa: 'Acciona', role: 'agile_coach · consultor_ia', desc: 'Transformación Agile en Mobility, gestión de roadmaps en TIC Construcción y estrategia de adopción de IA para 40.000+ personas.' },
  { when: '2018 – 2019', now: false, empresa: 'Kairos / MasMovil', role: 'scrum_master', desc: 'Primer proyecto en Kairos como consultor, con MasMovil en plena fase de crecimiento acelerado hacia los cuatro grandes del mercado.' },
  { when: '~2006 – 2017', now: false, empresa: 'Accenture', role: 'líder_técnico · 11 años', desc: 'Once años liderando proyectos de desarrollo de software para múltiples clientes en distintos sectores.' },
];

const stack = [
  { cat: 'framework', name: 'Agile · Nexus' },
  { cat: 'planning',  name: 'Jira Adv. Roadmaps' },
  { cat: 'automation', name: 'Python' },
  { cat: 'ai · llms', name: 'Claude / Anthropic' },
  { cat: 'workspace', name: 'Google Workspace' },
  { cat: 'analytics', name: 'PowerBI' },
  { cat: 'knowledge', name: 'Obsidian' },
  { cat: 'web',       name: 'Astro' },
];
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio y blog de Pedro García — Agile Coach y estratega de IA." />
  <title>Pedro García · Agile Coach & AI Strategy</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <style>
    /* ── Scroll progress bar ── */
    .scroll-bar{position:fixed;top:0;left:0;height:2px;background:var(--accent);width:0%;z-index:50;transition:width .08s linear}

    /* ── Generation overlay ── */
    .gen-overlay{
      position:fixed;inset:0;z-index:100;background:rgba(10,10,10,.94);
      display:flex;align-items:center;justify-content:center;
      backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);
      opacity:1;transition:opacity .5s ease;padding:24px;
    }
    .gen-overlay.done{opacity:0;pointer-events:none}
    .gen-window{
      width:min(640px,100%);background:var(--card);border:var(--bd);
      border-radius:var(--r-xl);overflow:hidden;
      font-family:var(--font-mono);font-size:13px;
      box-shadow:0 0 0 1px rgba(197,255,74,.06);
    }
    .gen-head{
      display:flex;align-items:center;gap:12px;padding:12px 16px;
      border-bottom:var(--bd);background:var(--bg-2);
      font-size:11px;color:var(--text-3);
    }
    .gen-head .dots{display:flex;gap:5px}
    .gen-head .dots i{width:9px;height:9px;border-radius:50%;background:rgba(255,255,255,.14)}
    .gen-head .path{flex:1;color:var(--text-2)}
    .gen-head .path b{color:var(--text);font-weight:500}
    .gen-head .status{color:var(--accent);display:flex;align-items:center;gap:6px;text-transform:uppercase;letter-spacing:.06em}
    .gen-body{padding:22px 22px 24px;min-height:160px;display:flex;flex-direction:column;gap:8px}
    .gen-line{display:flex;gap:10px;align-items:flex-start;line-height:1.65}
    .gen-marker{flex-shrink:0;color:var(--text-3);width:14px;text-align:right}
    .gen-marker.accent{color:var(--accent)}
    .gen-text{color:var(--text);flex:1;white-space:pre-wrap;word-wrap:break-word;min-height:1.65em}
    .gen-prompt .gen-text{color:var(--text-2)}
    .gen-cursor{display:inline-block;width:7px;height:13px;background:var(--accent);vertical-align:-1px;margin-left:2px;animation:blink 1s steps(2) infinite}
    @keyframes blink{50%{opacity:0}}
    .gen-skip{
      align-self:flex-end;margin-top:auto;
      background:transparent;border:var(--bd);color:var(--text-3);
      font:inherit;font-size:11px;padding:5px 10px;border-radius:var(--r-sm);
      cursor:pointer;transition:all var(--dur-fast);
    }
    .gen-skip:hover{border-color:var(--text-3);color:var(--text)}

    /* ── Nav ── */
    nav.top{position:sticky;top:0;z-index:30;background:rgba(10,10,10,.72);backdrop-filter:saturate(160%) blur(14px);-webkit-backdrop-filter:saturate(160%) blur(14px);border-bottom:var(--bd)}
    nav.top .row{display:flex;align-items:center;justify-content:space-between;height:56px;gap:24px}
    nav.top .brand{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:var(--fw-medium);letter-spacing:-.005em;color:var(--text)}
    nav.top .brand .mark{width:24px;height:24px;border-radius:var(--r-sm);background:var(--accent);color:var(--bg);display:inline-flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-weight:var(--fw-semi);font-size:13px}
    nav.top ul{display:flex;gap:0;list-style:none;margin:0;padding:0}
    nav.top ul a{display:flex;align-items:center;gap:6px;padding:8px 14px;font-size:13px;color:var(--text-2);border-radius:var(--r-sm);transition:color var(--dur-fast),background var(--dur-fast)}
    nav.top ul a:hover{color:var(--text);background:rgba(255,255,255,.04)}
    nav.top ul a .num{font-family:var(--font-mono);color:var(--text-3);font-size:11px}
    nav.top .right{display:flex;gap:10px;align-items:center}
    .kbd{display:inline-flex;align-items:center;gap:4px;padding:4px 8px;border-radius:var(--r-sm);background:rgba(255,255,255,.04);border:var(--bd);font-family:var(--font-mono);font-size:11px;color:var(--text-3)}
    .kbd kbd{font-family:inherit}

    /* ── Statusbar ── */
    .statusbar{border-bottom:var(--bd);background:var(--bg-2);font-family:var(--font-mono);font-size:11px;color:var(--text-3)}
    .statusbar .row{display:flex;align-items:center;gap:24px;height:32px;overflow:hidden;white-space:nowrap}
    .statusbar .item{display:inline-flex;align-items:center;gap:8px}
    .statusbar .item b{color:var(--text);font-weight:500}
    .statusbar .sep{color:var(--line-2)}

    /* ── Hero ── */
    .hero{padding:80px 0 64px;border-bottom:var(--bd);position:relative;z-index:1}
    .hero-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:48px;align-items:start}
    .hero-right{display:grid;grid-template-columns:1fr;gap:14px;transition:grid-template-columns .6s cubic-bezier(.4,0,.2,1)}
    .hero-right.with-photo{grid-template-columns:auto 1fr;align-items:start}
    .hero-photo{
      position:relative;border-radius:var(--r-xl);overflow:hidden;
      border:var(--bd);background:var(--bg-2);
      width:0;aspect-ratio:3/4;opacity:0;
      transition:opacity .8s ease,width .6s cubic-bezier(.4,0,.2,1),transform .8s cubic-bezier(.4,0,.2,1);
      transform:translateY(8px) scale(.98);
    }
    .hero-right.with-photo .hero-photo{width:170px}
    .hero-right.with-photo .hero-photo.shown{opacity:1;transform:translateY(0) scale(1)}
    .hero-photo img{width:100%;height:100%;object-fit:cover;display:block;filter:grayscale(.15) contrast(1.02)}
    .hero-photo .ph-tag{
      position:absolute;left:8px;bottom:8px;
      font-family:var(--font-mono);font-size:10px;
      padding:3px 8px;border-radius:var(--r-sm);
      background:rgba(10,10,10,.7);color:var(--accent);
      backdrop-filter:blur(4px);border:1px solid rgba(197,255,74,.2);
      display:inline-flex;align-items:center;gap:6px;
    }
    .hero h1{font-size:var(--fs-hero);line-height:.94;letter-spacing:var(--ls-tight);font-weight:var(--fw-medium);margin:0 0 32px;color:var(--text)}
    .hero h1 .accent{color:var(--accent)}
    .hero h1 .light{color:var(--text-2);font-weight:var(--fw-light)}
    .hero .lede{font-size:var(--fs-lede);line-height:1.5;color:var(--text-2);max-width:54ch;margin:0 0 32px;font-weight:var(--fw-regular)}
    .hero .lede strong{color:var(--text);font-weight:var(--fw-medium)}
    .hero h1[data-typing],.hero .lede[data-typing]{opacity:0;transition:opacity .15s ease}
    .hero h1[data-typing].ready,.hero .lede[data-typing].ready{opacity:1}

    /* ── Info card ── */
    .info-card{background:var(--card);border:var(--bd);border-radius:var(--r-xl);padding:0;overflow:hidden;transition:max-height .55s cubic-bezier(.4,0,.2,1)}
    .info-card .card-head{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:var(--bd);font-family:var(--font-mono);font-size:11px;color:var(--text-3);background:var(--bg-2)}
    .info-card .card-head .lhs{display:flex;align-items:center;gap:8px}
    .info-card .card-head .v{color:var(--accent)}
    .info-card .card-head .compact-tag{margin-left:8px;padding:2px 6px;border-radius:4px;background:rgba(197,255,74,.08);color:var(--accent);font-size:10px;opacity:0;transition:opacity .3s ease .15s}
    .info-card.compact .card-head .compact-tag{opacity:1}
    .info-card dl{margin:0;padding:8px 16px;display:grid;grid-template-columns:auto 1fr;gap:0;transition:padding .45s ease}
    .info-card dl > div{display:contents}
    .info-card dt,.info-card dd{padding:9px 0;border-bottom:var(--bd);font-family:var(--font-mono);font-size:12px;transition:max-height .45s ease,opacity .35s ease,padding .35s ease}
    .info-card dt{color:var(--text-3);padding-right:24px}
    .info-card dd{color:var(--text);text-align:right;margin:0}
    .info-card dl > div:last-child dt,.info-card dl > div:last-child dd{border-bottom:0}
    .info-card dl > div.collapsed dt,.info-card dl > div.collapsed dd{padding:0;border:0;margin:0;max-height:0;overflow:hidden;font-size:0;line-height:0;opacity:0}
    .info-card.compact dl{padding:6px 16px}
    .info-card.compact dt,.info-card.compact dd{padding:6px 0;font-size:11.5px}

    /* ── Sections ── */
    section.sec{padding:88px 0;border-bottom:var(--bd);position:relative;z-index:1}

    /* ── Bento grid ── */
    .bento{display:grid;grid-template-columns:repeat(6,1fr);grid-auto-rows:minmax(180px,auto);gap:12px}
    .tile{background:var(--card);border:var(--bd);border-radius:var(--r-xl);padding:var(--s-5);display:flex;flex-direction:column;gap:var(--s-3);transition:border-color var(--dur-fast),background var(--dur-fast);position:relative;overflow:hidden;cursor:pointer}
    .tile:hover{border-color:var(--text-3);background:var(--surface)}
    .tile .meta{display:flex;align-items:center;justify-content:space-between;font-family:var(--font-mono);font-size:11px;color:var(--text-3)}
    .tile .meta .org{color:var(--text)}
    .tile h3{font-size:var(--fs-h3);line-height:1.2;letter-spacing:var(--ls-tight-4);font-weight:var(--fw-medium);margin:0}
    .tile p{margin:0;color:var(--text-2);font-size:13.5px;line-height:1.55}
    .tile .footer{margin-top:auto;display:flex;justify-content:space-between;align-items:center}
    .tile .read{font-family:var(--font-mono);font-size:11px;color:var(--accent);display:inline-flex;align-items:center;gap:6px}
    .tile:hover .read{text-decoration:underline}
    .tile.feature{grid-column:span 4;grid-row:span 2}
    .tile.feature h3{font-size:var(--fs-h2);letter-spacing:var(--ls-tight-3);line-height:1.1}
    .tile.feature p{font-size:var(--fs-body-l);max-width:50ch}
    .tile.feature .visual{margin-top:auto;height:120px;border-radius:var(--r-md);background:linear-gradient(135deg,rgba(197,255,74,.18),rgba(197,255,74,0) 60%),var(--bg-2);border:var(--bd);position:relative;overflow:hidden;font-family:var(--font-mono);font-size:11px;color:var(--text-3)}
    .tile.feature .visual .dots{position:absolute;inset:16px;background-image:radial-gradient(circle,var(--text-3) 1px,transparent 1px);background-size:14px 14px;opacity:.25}
    .tile.feature .visual .label{position:absolute;left:16px;bottom:14px;color:var(--accent);font-weight:500}
    .tile.feature .visual .label-r{position:absolute;right:16px;top:14px;color:var(--text-3)}
    .tile.span-2{grid-column:span 2}

    /* ── Metrics ── */
    .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:12px}
    .metric-card{background:var(--card);border:var(--bd);border-radius:var(--r-xl);padding:var(--s-5);display:flex;flex-direction:column;gap:var(--s-2);transition:border-color var(--dur-fast)}
    .metric-card:hover{border-color:var(--accent)}
    .metric-card .lbl{font-family:var(--font-mono);font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em}
    .metric-card .big{font-size:48px;line-height:1;letter-spacing:-.03em;font-weight:var(--fw-medium);color:var(--text);font-feature-settings:"lnum" 1,"tnum" 1}
    .metric-card .big .unit{font-size:.4em;color:var(--text-3);margin-left:4px;font-weight:var(--fw-regular)}
    .metric-card .big .accent{color:var(--accent)}
    .metric-card .ctx{font-size:12px;color:var(--text-2);line-height:1.45}

    /* ── Timeline ── */
    .timeline{display:flex;flex-direction:column;gap:0;border-top:var(--bd)}
    .tl-row{display:grid;grid-template-columns:140px 1fr 200px;gap:32px;padding:24px 0;border-bottom:var(--bd);align-items:center;transition:padding-left .25s,background .25s}
    .tl-row:hover{padding-left:16px;background:rgba(255,255,255,.02)}
    .tl-row .when{font-family:var(--font-mono);font-size:12px;color:var(--text-3)}
    .tl-row .when .now-tag{color:var(--accent)}
    .tl-row .core h3{font-size:var(--fs-h3-l);line-height:1.2;letter-spacing:var(--ls-tight-4);font-weight:var(--fw-medium);margin:0 0 4px}
    .tl-row .core .role{font-family:var(--font-mono);font-size:12px;color:var(--text-2);margin:0}
    .tl-row .desc{color:var(--text-2);font-size:13px;line-height:1.55;margin:0}

    /* ── Stack ── */
    .stack-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}

    /* ── Footer ── */
    footer.site-footer{padding:80px 0 48px;border-top:var(--bd);position:relative;z-index:1}
    footer.site-footer .big{font-size:var(--fs-footer-big);line-height:.92;letter-spacing:var(--ls-tight);font-weight:var(--fw-medium);margin:0 0 56px}
    footer.site-footer .big .accent{color:var(--accent)}
    footer.site-footer .big .light{color:var(--text-2);font-weight:var(--fw-light)}
    footer.site-footer .row{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;padding-top:32px;border-top:var(--bd)}
    footer.site-footer .col h4{font-family:var(--font-mono);font-size:11px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;margin:0 0 12px;font-weight:var(--fw-medium)}
    footer.site-footer .col a,footer.site-footer .col p{display:block;color:var(--text);font-size:14px;margin:0 0 6px;transition:color var(--dur-fast)}
    footer.site-footer .col a:hover{color:var(--accent)}
    footer.site-footer .col p{color:var(--text-2)}
    footer.site-footer .meta{margin-top:32px;display:flex;justify-content:space-between;color:var(--text-3);font-size:11px;font-family:var(--font-mono);flex-wrap:wrap;gap:12px}

    /* ── Responsive ── */
    @media(max-width:960px){
      .wrap{padding:0 20px}
      nav.top ul{display:none}
      nav.top .kbd{display:none}
      .statusbar .row{gap:12px}
      .statusbar .item.m{display:none}
      .hero{padding:48px 0 32px}
      .hero-grid{grid-template-columns:1fr;gap:24px}
      .hero-right{order:-1}
      .hero-right.with-photo{grid-template-columns:140px 1fr}
      .hero-right.with-photo .hero-photo{width:140px}
      section.sec{padding:56px 0}
      .bento{grid-template-columns:repeat(2,1fr);grid-auto-rows:auto}
      .tile.feature{grid-column:span 2;grid-row:auto}
      .tile.span-2{grid-column:span 2}
      .tile.feature h3{font-size:24px}
      .metrics{grid-template-columns:repeat(2,1fr)}
      .metric-card .big{font-size:36px}
      .tl-row{grid-template-columns:1fr;gap:8px}
      .tl-row .when{order:-1}
      .stack-grid{grid-template-columns:repeat(2,1fr)}
      footer.site-footer .row{grid-template-columns:repeat(2,1fr)}
    }
  </style>
</head>
<body>

<!-- Overlay generación -->
<div class="gen-overlay" id="gen" aria-hidden="true">
  <div class="gen-window">
    <div class="gen-head">
      <span class="dots"><i></i><i></i><i></i></span>
      <span class="path">~/<b>pedro-garcia.dev</b> · claude-haiku-4.5</span>
      <span class="status"><span class="live-dot"></span>streaming</span>
    </div>
    <div class="gen-body">
      <div class="gen-line gen-prompt">
        <span class="gen-marker">&gt;</span>
        <span class="gen-text" id="genPrompt"></span>
      </div>
      <div class="gen-line">
        <span class="gen-marker accent">›</span>
        <span class="gen-text" id="genOut"></span><span class="gen-cursor" id="genCursor"></span>
      </div>
      <button class="gen-skip" id="genSkip" type="button">saltar intro →</button>
    </div>
  </div>
</div>

<div class="scroll-bar" id="scrollbar"></div>

<!-- Nav -->
<nav class="top">
  <div class="wrap row">
    <a href={`${base}/`} class="brand"><span class="mark">P</span>pedro-garcia.dev</a>
    <ul>
      <li><a href="#proyectos"><span class="num">01</span>Proyectos</a></li>
      <li><a href="#trayectoria"><span class="num">02</span>Trayectoria</a></li>
      <li><a href="#logros"><span class="num">03</span>Logros</a></li>
      <li><a href="#stack"><span class="num">04</span>Stack</a></li>
      <li><a href={`${base}/blog`}><span class="num">05</span>Blog</a></li>
    </ul>
    <div class="right">
      <span class="kbd"><kbd>⌘</kbd><kbd>K</kbd>&nbsp;buscar</span>
    </div>
  </div>
</nav>

<!-- Statusbar -->
<div class="statusbar">
  <div class="wrap row">
    <span class="item"><span class="live-dot"></span>disponible para colaborar</span>
    <span class="sep">·</span>
    <span class="item m">Madrid, ES <b>+CET</b></span>
    <span class="sep m">·</span>
    <span class="item m">build <b>2026.q4</b></span>
    <span class="sep m">·</span>
    <span class="item m" style="margin-left:auto;color:var(--accent)">/ahora · acciona · ai strategy</span>
  </div>
</div>

<!-- Hero -->
<header class="hero">
  <div class="wrap">
    <div class="hero-grid">
      <div>
        <div class="seclabel">
          <span class="num">/00</span>
          <span>introducción</span>
          <span class="line"></span>
          <span class="meta">agile_coach × ai_strategy</span>
        </div>
        <h1 data-typing>
          Pedro <span class="accent">García</span><br/>
          <span class="light">construye sistemas</span><br/>
          <span class="light">que escalan.</span>
        </h1>
        <p class="lede" data-typing>
          Trabajo en la intersección entre <strong>negocio, equipos y tecnología</strong>.
          Diseño <span class="shim" data-alts="frameworks ágiles|sistemas con IA|programas Key Players">frameworks ágiles</span> y programas de adopción de IA para organizaciones
          de ingeniería de <span class="shim" data-alts="40.000+ personas|decenas de equipos|el departamento entero">40.000+ personas</span>.
        </p>
        <div class="cta-row">
          <a href="#proyectos" class="btn primary">Ver proyectos <span class="arrow">→</span></a>
          <a href={`${base}/blog`} class="btn">Blog</a>
        </div>
      </div>
      <div class="hero-right">
        <div class="hero-photo" aria-hidden="true">
