---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos
    .filter(p => p.data.tags.includes('publicable'))
    .map(p => ({ params: { slug: p.id }, props: { proyecto: p } }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={proyecto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-slate-500 mb-10 flex items-center gap-2">
    <a href={`${base}/`} class="hover:text-slate-300 transition-colors">Inicio</a>
    <span>·</span>
    <a href={`${base}/proyectos`} class="hover:text-slate-300 transition-colors">Proyectos</a>
  </nav>

  <!-- Header -->
  <header class="mb-12">
    <div class="flex items-start gap-3 mb-3">
      <h1 class="text-3xl font-bold text-white tracking-tight">
        {proyecto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
      </h1>
      {proyecto.data.status === 'activo'
        ? <span class="badge-active self-start mt-1.5 shrink-0">activo</span>
        : proyecto.data.status
          ? <span class="badge-done self-start mt-1.5 shrink-0">completado</span>
          : null
      }
    </div>
    {proyecto.data.cliente && <p class="mono mb-3">{proyecto.data.cliente}</p>}
    {proyecto.data.periodo && <p class="text-sm text-slate-400">{proyecto.data.periodo}</p>}
    <div class="flex gap-2 flex-wrap mt-3">
      {proyecto.data.tags
        .filter(t => t !== 'publicable' && !t.startsWith('wiki/'))
        .map(tag => (
          <span class="glass text-xs text-slate-400 px-2 py-0.5 rounded">{tag}</span>
        ))
      }
    </div>
  </header>

  <!-- Contenido -->
  <article class="prose max-w-none">
    <Content />
  </article>
</Layout>
