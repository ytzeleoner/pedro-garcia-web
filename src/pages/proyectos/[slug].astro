---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos
    .filter(p => p.data.tags.includes('publicable'))
    .map(p => ({ params: { slug: p.id }, props: { proyecto: p } }));
}

const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={proyecto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}>
  <!-- Breadcrumb -->
  <nav style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);margin-bottom:var(--s-8);display:flex;align-items:center;gap:var(--s-2);">
    <a href={`${base}/`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Inicio</a>
    <span>·</span>
    <a href={`${base}/proyectos`} style="color:var(--text-3);transition:color var(--dur-fast);" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">Proyectos</a>
  </nav>

  <!-- Header -->
  <header style="margin-bottom:var(--s-9);">
    <div style="display:flex;align-items:flex-start;gap:var(--s-3);margin-bottom:var(--s-3);">
      <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);letter-spacing:var(--ls-tight-3);line-height:1.1;">
        {proyecto.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
      </h1>
      {proyecto.data.status === 'activo'
        ? <span class="badge-active" style="flex-shrink:0;margin-top:6px;">activo</span>
        : proyecto.data.status
          ? <span class="badge-done" style="flex-shrink:0;margin-top:6px;">completado</span>
          : null
      }
    </div>
    {proyecto.data.cliente && <p class="mono" style="margin-bottom:var(--s-2);">{proyecto.data.cliente}</p>}
    {proyecto.data.periodo && <p style="font-size:13px;color:var(--text-3);">{proyecto.data.periodo}</p>}
    <div style="display:flex;gap:var(--s-2);flex-wrap:wrap;margin-top:var(--s-3);">
      {proyecto.data.tags
        .filter((t: string) => t !== 'publicable' && !t.startsWith('wiki/'))
        .map((tag: string) => (
          <span style="background:var(--card);border:var(--bd);border-radius:var(--r-sm);padding:2px var(--s-2);font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-3);">{tag}</span>
        ))
      }
    </div>
  </header>

  <!-- Contenido -->
  <article class="prose" style="max-width:none;">
    <Content />
  </article>
</Layout>
