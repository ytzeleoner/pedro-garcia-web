---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos'))
  .filter(p => p.data.tags.includes('publicable'))
  .sort((a, b) => (b.data.created?.getTime() ?? 0) - (a.data.created?.getTime() ?? 0));
---

<Layout title="Proyectos">
  <h1 class="text-2xl font-bold mb-2">Proyectos</h1>
  <p class="text-gray-500 mb-10 text-sm">Síntesis de proyectos notables — contexto, problema, solución y resultado.</p>

  <div class="space-y-4">
    {proyectos.map(p => (
      <a href={`/proyectos/${p.id}`} class="flex items-start justify-between gap-4 border border-gray-200 rounded-lg p-5 hover:border-blue-300 hover:shadow-sm transition-all">
        <div>
          <h2 class="font-semibold text-gray-900 mb-1">
            {p.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
          </h2>
          <div class="flex gap-2 flex-wrap">
            {p.data.tags.filter(t => t !== 'publicable' && !t.startsWith('wiki/')).slice(0, 4).map(tag => (
              <span class="text-xs text-gray-500 bg-gray-50 px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
        </div>
        {p.data.status && (
          <span class={`text-xs px-2 py-1 rounded-full shrink-0 self-start ${p.data.status === 'activo' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500'}`}>
            {p.data.status}
          </span>
        )}
      </a>
    ))}
  </div>
</Layout>
