---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos'))
  .filter(p => p.data.tags.includes('publicable'))
  .sort((a, b) => (b.data.created?.getTime() ?? 0) - (a.data.created?.getTime() ?? 0));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const porCliente: Record<string, typeof proyectos> = {};
for (const p of proyectos) {
  const cliente = p.data.cliente ?? 'Otros';
  if (!porCliente[cliente]) porCliente[cliente] = [];
  porCliente[cliente].push(p);
}

const ordenClientes = ['Acciona', 'Kairos / MasMovil', 'Accenture', 'Otros'];
const clientesOrdenados = [
  ...ordenClientes.filter(c => porCliente[c]),
  ...Object.keys(porCliente).filter(c => !ordenClientes.includes(c)),
];

const titulos: Record<string, string> = {
  'rol-ia-acciona': 'Estrategia de IA en Ingeniería',
  'adaptador-iniciativas-jira': 'Automatización Jira + Google Sheets',
  'transformacion-agile-mobility': 'Transformación Agile a escala',
  'scrum-master-masmovil-kairos': 'Scrum Master en MasMovil',
  'lider-tecnico-accenture': 'Líder técnico — Accenture',
};
---

<Layout title="Proyectos">
  <p class="mono mb-3">proyectos</p>
  <h1 class="text-3xl font-bold text-white mb-3 tracking-tight">Proyectos</h1>
  <p class="text-slate-400 mb-14 max-w-lg">Síntesis de proyectos notables — contexto, problema, solución y resultado.</p>

  {clientesOrdenados.map(cliente => (
    <div class="mb-14">
      <div class="flex items-center gap-3 mb-5">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center text-xs font-bold shrink-0"
             style="background: rgba(139,92,246,0.15); color: #a78bfa; border: 1px solid rgba(139,92,246,0.25);">
          {cliente.slice(0, 2).toUpperCase()}
        </div>
        <h2 class="text-sm font-semibold text-slate-300 uppercase tracking-widest">{cliente}</h2>
      </div>

      <div class="space-y-3">
        {porCliente[cliente].map(p => (
          <a href={`${base}/proyectos/${p.id}`} class="glass p-5 flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold text-white mb-1">
                {titulos[p.id] ?? p.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
              </h3>
              {p.data.periodo && <p class="mono mt-1">{p.data.periodo}</p>}
            </div>
            {p.data.status === 'activo'
              ? <span class="badge-active shrink-0 self-start">activo</span>
              : <span class="badge-done shrink-0 self-start">completado</span>
            }
          </a>
        ))}
      </div>
    </div>
  ))}
</Layout>
