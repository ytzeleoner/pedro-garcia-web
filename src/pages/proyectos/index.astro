---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const proyectos = (await getCollection('proyectos'))
  .filter(p => p.data.tags.includes('publicable'))
  .sort((a, b) => (b.data.created?.getTime() ?? 0) - (a.data.created?.getTime() ?? 0));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const porCliente: Record<string, typeof proyectos> = {};
for (const p of proyectos) {
  const cliente = p.data.cliente ?? 'Otros';
  if (!porCliente[cliente]) porCliente[cliente] = [];
  porCliente[cliente].push(p);
}

const ordenClientes = ['Acciona', 'Kairos / MasMovil', 'Accenture', 'Otros'];
const clientesOrdenados = [
  ...ordenClientes.filter(c => porCliente[c]),
  ...Object.keys(porCliente).filter(c => !ordenClientes.includes(c)),
];

const titulos: Record<string, string> = {
  'rol-ia-acciona': 'Estrategia de IA en Ingeniería',
  'adaptador-iniciativas-jira': 'Automatización Jira + Google Sheets',
  'transformacion-agile-mobility': 'Transformación Agile a escala',
  'scrum-master-masmovil-kairos': 'Scrum Master en MasMovil',
  'lider-tecnico-accenture': 'Líder técnico — Accenture',
};
---

<Layout title="Proyectos">
  <p class="mono" style="margin-bottom:var(--s-3);">proyectos</p>
  <h1 style="font-size:var(--fs-h2);font-weight:var(--fw-bold);color:var(--text);margin-bottom:var(--s-3);letter-spacing:var(--ls-tight-3);">Proyectos</h1>
  <p style="color:var(--text-2);margin-bottom:var(--s-9);max-width:52ch;">Síntesis de proyectos notables — contexto, problema, solución y resultado.</p>

  {clientesOrdenados.map(cliente => (
    <div style="margin-bottom:var(--s-9);">
      <div style="display:flex;align-items:center;gap:var(--s-3);margin-bottom:var(--s-5);">
        <div style="width:36px;height:36px;border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:var(--fs-mono);font-weight:var(--fw-bold);flex-shrink:0;background:var(--accent-soft);color:var(--accent);border:1px solid rgba(197,255,74,.2);font-family:var(--font-mono);">
          {cliente.slice(0, 2).toUpperCase()}
        </div>
        <h2 style="font-family:var(--font-mono);font-size:var(--fs-mono);color:var(--text-2);letter-spacing:var(--ls-wide);text-transform:uppercase;">{cliente}</h2>
      </div>

      <div style="display:flex;flex-direction:column;gap:var(--s-3);">
        {porCliente[cliente].map(p => (
          <a href={`${base}/proyectos/${p.id}`} class="glass" style="padding:var(--s-5);display:flex;align-items:flex-start;justify-content:space-between;gap:var(--s-4);">
            <div>
              <h3 style="font-weight:var(--fw-semi);color:var(--text);margin-bottom:var(--s-1);">
                {titulos[p.id] ?? p.id.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
              </h3>
              {p.data.periodo && <p class="mono" style="margin-top:var(--s-1);">{p.data.periodo}</p>}
            </div>
            {p.data.status === 'activo'
              ? <span class="badge-active" style="flex-shrink:0;align-self:flex-start;">activo</span>
              : <span class="badge-done" style="flex-shrink:0;align-self:flex-start;">completado</span>
            }
          </a>
        ))}
      </div>
    </div>
  ))}
</Layout>
